{
  "name": "@hochfrequenz/efoli",
  "version": "0.0.0",
  "description": "enums for edifact formats and format versions used by German utilities",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "prepack": "npm run build"
  },
  "keywords": [
    "edifact",
    "german-utilities",
    "enums",
    "format-versions",
    "mako"
  ],
  "homepage": "https://github.com/Hochfrequenz/efoli.ts#readme",
  "bugs": {
    "url": "https://github.com/Hochfrequenz/efoli.ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hochfrequenz/efoli.ts.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
